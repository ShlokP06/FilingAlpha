# Postgres
POSTGRES_DB=filing_alpha
POSTGRES_USER=filing
POSTGRES_PASSWORD=filing
DATABASE_URL=postgresql+psycopg://filing:filing@localhost:5432/filing_alpha

# SEC EDGAR requires a declared identity (name + email) on every request.
SEC_IDENTITY=FilingAlpha research che240008027@iiti.ac.in

# Paths
DATA_DIR=data/raw

# Ingestion robustness (Yahoo/SEC rate-limit handling). Defaults are sensible;
# override only if you still see throttling at scale. yfinance manages its own
# curl_cffi impersonation session; robustness comes from chunked bulk fetches,
# a pause between chunks, backoff retries, and the per-firm ingest_state machine.
# YF_CHUNK_SIZE=30
# YF_CHUNK_PAUSE=1.0
# YF_MAX_RETRIES=5
# SEC_MAX_RETRIES=3
# After this many consecutive throttled bulk chunks, stop price fetches this run
# and mark the rest 'failed' (retried next run) instead of hammering Yahoo.
# YF_MAX_FAILED_CHUNKS=3
# Set to false to skip per-filing full-text downloads (faster; whole-document
# signals then fall back to the extracted Item 1A / Item 7 sections).
# INGEST_FULL_TEXT=true

# Grafana
GRAFANA_PASSWORD=admin

# Report narrative LLM (optional). With no key the research note uses a
# deterministic template instead of an LLM, so this is not required to run.
LLM_PROVIDER=cerebras
LLM_MODEL=llama-3.3-70b
# CEREBRAS_API_KEY=
# GROQ_API_KEY=
