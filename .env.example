# Postgres
POSTGRES_DB=filing_alpha
POSTGRES_USER=filing
POSTGRES_PASSWORD=filing
DATABASE_URL=postgresql+psycopg://filing:filing@localhost:5432/filing_alpha

# SEC EDGAR requires a declared identity (name + email) on every request.
SEC_IDENTITY=FilingAlpha research che240008027@iiti.ac.in

# Paths
DATA_DIR=data/raw

# Grafana
GRAFANA_PASSWORD=admin

# Report narrative LLM (optional). With no key the research note uses a
# deterministic template instead of an LLM, so this is not required to run.
LLM_PROVIDER=cerebras
LLM_MODEL=llama-3.3-70b
# CEREBRAS_API_KEY=
# GROQ_API_KEY=
